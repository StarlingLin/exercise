<Window x:Class="WeatherForecastApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WeatherForecastApp.ViewModels"
        Title="天气预报应用"
        Height="520"
        Width="820"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3F8">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="32">
        <Border CornerRadius="24"
        Background="White"
        Padding="32">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                          ShadowDepth="4"
                          Opacity="0.18" />
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="天气预报应用"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#1F2937" />

                    <TextBlock Text="自动定位 · 实时天气 · XML离线缓存"
                               Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#6B7280" />
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,42,0,36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding City}"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="#111827" />

                        <TextBlock Text="{Binding Country}"
                                   FontSize="18"
                                   Foreground="#6B7280"
                                   Margin="0,6,0,0" />

                        <TextBlock Text="{Binding WeatherDescription}"
                                   FontSize="24"
                                   Foreground="#2563EB"
                                   Margin="0,32,0,0" />

                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="14"
                                   Foreground="#9CA3AF"
                                   Margin="0,24,0,0" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#F3F6FB"
                            CornerRadius="20"
                            Padding="28">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding TemperatureKelvin}"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       HorizontalAlignment="Center" />

                            <TextBlock Text="开尔文温度"
                                       FontSize="14"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,28" />

                            <TextBlock Text="{Binding Humidity}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       HorizontalAlignment="Center" />

                            <TextBlock Text="湿度"
                                       FontSize="14"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <DockPanel Grid.Row="2">
                    <TextBlock Text="{Binding LastUpdated}"
                               Foreground="#6B7280"
                               FontSize="13"
                               DockPanel.Dock="Left" />

                    <Button Content="刷新天气"
                            Width="120"
                            Height="36"
                            DockPanel.Dock="Right"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Command="{Binding RefreshWeatherCommand}" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>